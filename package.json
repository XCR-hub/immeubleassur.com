{
  "name": "immeubleassur.com",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "check": "node --check assets/app.js && node --check functions/api/leads.js",
    "dev": "wrangler pages dev . --compatibility-date=2026-07-19",
    "db:init": "wrangler d1 execute immeubleassur-db --local --file=./schema.sql",
    "db:remote": "wrangler d1 execute immeubleassur-db --remote --file=./schema.sql",
    "deploy": "wrangler pages deploy . --project-name=immeubleassur-com"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
